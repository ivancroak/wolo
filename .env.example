# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.
# ADMIN_WALLET_ADDRESS: public key of your platform admin wallet (can be same as SOLANA_DEPLOY_WALLET_ADDRESS).
# TWITTER_VERIFY_SECRET: must be different from SESSION_SECRET. Generate: openssl rand -hex 32

# Solana / Anchor
SOLANA_DEPLOY_WALLET_PRIVATE_KEY=your_base58_encoded_deploy_wallet_private_key
SOLANA_DEPLOY_WALLET_ADDRESS=your_deploy_wallet_public_key
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_ESCROW_PROGRAM_ID=your_escrow_program_id
NEXT_PUBLIC_REPUTATION_PROGRAM_ID=your_reputation_program_id
NEXT_PUBLIC_FEE_VAULT=your_fee_vault_public_key

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Auth
SESSION_SECRET=a_long_random_string_min_32_chars
ADMIN_WALLET_ADDRESS=your_admin_wallet_public_key

# Twitter / X verification oracle
TWITTER_API_KEY=your_twitterapi_io_key
TWITTER_VERIFY_SECRET=a_separate_random_string_for_hmac_min_32_chars

# Email
RESEND_API_KEY=your_resend_api_key

# AI Agent (Groq — powers marketplace chatbot search)
GROQ_API_KEY=your_groq_api_key
